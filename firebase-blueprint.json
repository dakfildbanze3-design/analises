{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "products": {
      "title": "Product",
      "description": "Stores product listings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "sellerId": { "type": "string" },
        "sellerPhone": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "sellerId", "createdAt"]
    },
    "chats": {
      "title": "Chat",
      "description": "Stores user conversations",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "otherUserName": { "type": "string" },
        "otherUserAvatar": { "type": "string" },
        "unread": { "type": "boolean" },
        "unreadCount": { "type": "number" },
        "online": { "type": "boolean" }
      },
      "required": ["participants"]
    },
    "notifications": {
      "title": "Notification",
      "description": "Stores user notifications and alerts",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "comment", "follow"] },
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "postId": { "type": "string" },
        "text": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "fromUserId", "toUserId", "text", "read", "createdAt"]
    },
    "user_settings": {
      "title": "User Settings",
      "description": "Stores user application preferences",
      "type": "object",
      "properties": {
        "pushNotifications": { "type": "boolean" },
        "invisibleProfile": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "follows": {
      "title": "Follow",
      "description": "Stores follow relationships between users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string", "description": "UID of the user following" },
        "followingId": { "type": "string", "description": "UID of the user being followed" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "calls": {
      "title": "Call",
      "description": "Stores WebRTC signaling data for video and audio calls",
      "type": "object",
      "properties": {
        "caller_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "status": { "type": "string", "enum": ["calling", "ringing", "accepted", "rejected", "ended"] },
        "type": { "type": "string", "enum": ["video", "audio"] },
        "created_at": { "type": "string", "format": "date-time" },
        "offer": { "type": "object" },
        "answer": { "type": "object" }
      },
      "required": ["caller_id", "receiver_id", "status", "type", "created_at"]
    },
    "search_history": {
      "title": "Search History",
      "description": "Stores user search history queries",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "timestamp"]
    },
    "chat_settings": {
      "title": "Chat Settings",
      "description": "Per-user settings for a specific chat",
      "type": "object",
      "properties": {
        "chat_id": { "type": "string" },
        "user_id": { "type": "string" },
        "muted": { "type": "boolean" },
        "pinned": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chat_id", "user_id"]
    },
    "blocked_users": {
      "title": "Blocked User",
      "description": "Stores blocking relationships between users",
      "type": "object",
      "properties": {
        "blocker_id": { "type": "string" },
        "blocked_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["blocker_id", "blocked_id", "created_at"]
    },
    "reports": {
      "title": "User Report",
      "description": "Stores abuse reports against users",
      "type": "object",
      "properties": {
        "reporter_id": { "type": "string" },
        "reported_id": { "type": "string" },
        "chat_id": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["reporter_id", "reported_id", "reason", "created_at"]
    },
    "messages": {
      "title": "Message",
      "description": "Stores individual chat messages",
      "type": "object",
      "properties": {
        "chat_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "audio", "image", "video", "call_log"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "seen"] }
      },
      "required": ["chat_id", "sender_id", "participants", "created_at"]
    },
    "candidates": {
      "title": "ICE Candidate",
      "description": "WebRTC Ice candidate for signaling",
      "type": "object",
      "properties": {
        "candidate": { "type": "object" },
        "type": { "type": "string", "enum": ["caller", "receiver"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    },
    "user_settings/{userId}": {
      "schema": "user_settings",
      "description": "User settings documents"
    },
    "products/{productId}": {
      "schema": "products",
      "description": "Product listing documents"
    },
    "chats/{chatId}": {
      "schema": "chats",
      "description": "User conversation documents"
    },
    "notifications/{notificationId}": {
      "schema": "notifications",
      "description": "User notification documents"
    },
    "follows/{followId}": {
      "schema": "follows",
      "description": "Follow relationship documents"
    },
    "calls/{callId}": {
      "schema": "calls",
      "description": "Video/Audio call signaling documents"
    },
    "search_history/{historyId}": {
      "schema": "search_history",
      "description": "User search history entries"
    },
    "chat_settings/{settingId}": {
      "schema": "chat_settings",
      "description": "User preferences for specific chats"
    },
    "messages/{messageId}": {
      "schema": "messages",
      "description": "Individual messages within a chat"
    },
    "calls/{callId}/callerCandidates/{candidateId}": {
      "schema": "candidates",
      "description": "WebRTC candidates from the caller"
    },
    "calls/{callId}/receiverCandidates/{candidateId}": {
      "schema": "candidates",
      "description": "WebRTC candidates from the receiver"
    },
    "blocked_users/{blockId}": {
      "schema": "blocked_users",
      "description": "User blocking relationships"
    },
    "reports/{reportId}": {
      "schema": "reports",
      "description": "User abuse reports"
    }
  }
}
